<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Establish a solid 108dp x 108dp canvas area to prevent zooming/stretching -->
    <item>
        <shape android:shape="rectangle">
            <size android:width="108dp" android:height="108dp"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- Centered foreground image, scaled to a safe size inside the 72dp safe zone -->
    <item
        android:drawable="@drawable/img_app_icon"
        android:width="64dp"
        android:height="64dp"
        android:gravity="center" />
</layer-list>
